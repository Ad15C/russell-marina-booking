<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Détail du Catway</title>
  <style>
    body { font-family: Arial, sans-serif; }
    form { margin: 5px 0; }
    input, select, button { margin: 2px; padding: 4px; }
    .message { color: green; }
    .error { color: red; }
  </style>
</head>
<body>
  <h1>Bienvenue <%= user.name %> sur le Port de Plaisance</h1>

  <% if (message) { %>
    <p class="message"><%= message %></p>
  <% } %>
  <% if (error) { %>
    <p class="error"><%= error %></p>
  <% } %>

  <h2>Détail du Catway sélectionné</h2>
  <p><strong>Numéro :</strong> <%= catway.catwayNumber %></p>
  <p><strong>Type :</strong> <%= catway.type %></p>
  <p><strong>État :</strong> <%= catway.catwayState %></p>

  <h2>Modifier ce Catway</h2>
  <form action="/catways/<%= catway._id %>" method="POST">
    <input type="hidden" name="_method" value="PUT">
    <input type="hidden" name="redirectTo" value="/catways"> 
    <select name="type">
      <option value="">--Type--</option>
      <option value="long" <%= catway.type === 'long' ? 'selected' : '' %>>Long</option>
      <option value="short" <%= catway.type === 'short' ? 'selected' : '' %>>Short</option>
    </select>
    <select name="catwayState" required>
        <option value="libre" <%= catway.catwayState === 'libre' ? 'selected' : '' %>>Libre</option>
        <option value="occupé" <%= catway.catwayState === 'occupé' ? 'selected' : '' %>>Occupé</option>
        <option value="en maintenance" <%= catway.catwayState === 'en maintenance' ? 'selected' : '' %>>En maintenance</option>
    </select>
    <button type="submit">Modifier</button>
  </form>

  <h2>Supprimer ce Catway</h2>
    <form 
    action="/catways/<%= catway._id %>" 
    method="POST"
    onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce catway ?');"
    >
    <input type="hidden" name="_method" value="DELETE">
    <button type="submit">Supprimer</button>
    </form>

  <hr>

  <p>
    <a href="/catways">← Retour à la liste des catways</a> |
    <a href="/dashboard">← Dashboard</a>
  </p>
</body>
</html>
