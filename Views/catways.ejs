<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Liste des Catways</title>
</head>
<body>
  <h1>Bienvenue <%= user.name %> sur le Port de Plaisance</h1>

  <h2>Liste des Catways</h2>
  <table border="1" cellpadding="5">
    <tr>
      <th>ID</th>
      <th>Numéro</th>
      <th>Type</th>
      <th>État</th>
      <th>Détails</th>
      <th>Modifier</th>
      <th>Supprimer</th>
    </tr>
    <% catways.forEach(catway => { %>
      <tr>
        <td><%= catway._id %></td>
        <td><%= catway.catwayNumber %></td>
        <td><%= catway.type %></td>
        <td><%= catway.catwayState %></td>
        <td><a href="/catways/<%= catway._id %>">Voir détail</a></td>
        <td>
          <form action="/catways/<%= catway._id %>?_method=PUT" method="POST">
            <input type="text" name="catwayNumber" value="<%= catway.catwayNumber %>" required />
            <select name="type" required>
              <option value="long" <%= catway.type === 'long' ? 'selected' : '' %>>Long</option>
              <option value="short" <%= catway.type === 'short' ? 'selected' : '' %>>Short</option>
            </select>
            <input type="text" name="catwayState" value="<%= catway.catwayState %>" required />
            <button type="submit">Modifier</button>
          </form>
        </td>
        <td>
          <form action="/catways/<%= catway._id %>?_method=DELETE" method="POST">
            <button type="submit">Supprimer</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </table>

  <hr>
  <h2>Créer un nouveau Catway</h2>
  <form action="/catways" method="POST">
    <input type="text" name="catwayNumber" placeholder="Numéro du catway" required />
    <select name="type" required>
      <option value="long">Long</option>
      <option value="short">Short</option>
    </select>
    <input type="text" name="catwayState" placeholder="État du catway" required />
    <button type="submit">Créer Catway</button>
  </form>

  <p><a href="/dashboard">← Retour au Dashboard</a></p>
</body>
</html>
