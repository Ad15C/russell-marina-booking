<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Détails de la Réservation</title>
  <style>
    body { font-family: Arial, sans-serif; }
    table { border-collapse: collapse; margin-bottom: 15px; }
    th, td { padding: 5px 10px; border: 1px solid #000; }
  </style>
</head>
<body>

  <h1>Détails de la Réservation</h1>
  <h2>Utilisateur connecté : <%= user.name %></h2>

  <table>
    <tr>
      <th>ID Réservation</th>
      <td><%= reservation._id %></td>
    </tr>
    <tr>
      <th>Catway</th>
      <td>
        <%= reservation.catwayNumber || reservation.catwayId?.catwayNumber %>
      </td>
    </tr>
    <tr>
      <th>Client</th>
      <td><%= reservation.clientName %></td>
    </tr>
    <tr>
      <th>Bateau</th>
      <td><%= reservation.boatName %></td>
    </tr>
    <tr>
      <th>Check-in</th>
      <td><%= new Date(reservation.checkIn).toLocaleDateString() %></td>
    </tr>
    <tr>
      <th>Check-out</th>
      <td><%= new Date(reservation.checkOut).toLocaleDateString() %></td>
    </tr>
  </table>

     <!-- Supprimer la réservation via dashboard -->
    <form method="POST" action="/reservations-dashboard/<%= reservation._id %>/delete">
        <button type="submit">Supprimer cette réservation</button>
    </form>


  <p>
    <a href="/reservations">← Retour à la liste des réservations</a> |
    <a href="/dashboard">← Retour au Dashboard</a>
  </p>

</body>
</html>
