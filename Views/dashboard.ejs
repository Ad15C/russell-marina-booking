<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Tableau de bord - Port de Plaisance</title>
</head>
<body>
  <h1>Bienvenue <%= user.name %> sur le Port de Plaisance de Russell</h1>
  
<form action="/api/auth/logout" method="POST">
  <button type="submit">Se déconnecter</button>
</form>

<hr>

  <h2>Gestion des utilisateurs</h2>

  <h3>Créer un nouvel utilisateur</h3>
  <form action="/api/users" method="POST">
    <input type="text" name="name" placeholder="Nom" required />
    <input type="email" name="email" placeholder="Email" required />
    <input type="password" name="password" placeholder="Mot de passe" required />
    <button type="submit">Créer Utilisateur</button>
  </form>
  
  <h3>Modifier un utilisateur</h3>

  <form action="/api/users" method="POST">
    <input type="hidden" name="_method" value="PUT" />
    <input type="text" name="name" placeholder="Nom existant" required />
    <input type="email" name="email" placeholder="Email existant" />
    <input type="text" name="newName" placeholder="Nouveau nom" />
    <input type="email" name="newEmail" placeholder="Nouvel email" />
    <input type="password" name="newPassword" placeholder="Nouveau mot de passe" />
    <button type="submit">Modifier utilisateur</button>
  </form>

  <h3>Supprimer un utilisateur</h3>
  <form action="/api/users" method="POST">
    <input type="hidden" name="_method" value="DELETE" />
    <input type="text" name="name" placeholder="Nom utilisateur" />
    <input type="email" name="email" placeholder="Email utilisateur" />
    <button type="submit">Supprimer utilisateur</button>
  </form>

  <!-- Message de succès ou erreur -->
  <% if (message) { %>
    <p style="color:green"><%= message %></p>
  <% } %>

  <% if (error) { %>
    <p style="color:red"><%= error %></p>
  <% } %>



  <h2>Liste des Catways</h2>
    <table border="1" cellpadding="5">
<tr>
  <th>ID</th>
  <th>Numéro</th>
  <th>Type</th>
  <th>État</th>
  <th>Actions</th>
</tr>

<% catways.forEach(catway => { %>
<tr>
  <td><%= catway.id %></td>
  <td><%= catway.catwayNumber %></td>
  <td><%= catway.type %></td>
  <td><%= catway.catwayState %></td>
  <td>
    <!-- Voir détail -->
    <a href="/catways/<%= catway._id %>">Voir</a>

    <!-- Modifier -->
    <form action="/catways/<%= catway._id %>/edit" method="POST" style="display:inline;">
      <select name="type">
        <option value="">--Type--</option>
        <option value="long" <%= catway.type === 'long' ? 'selected' : '' %>>Long</option>
        <option value="short" <%= catway.type === 'short' ? 'selected' : '' %>>Short</option>
      </select>
      <input type="text" name="catwayState" value="<%= catway.catwayState %>" />
      <button type="submit">Modifier</button>
    </form>

    <!-- Supprimer -->
    <form action="/catways/<%= catway._id %>/delete" method="POST" style="display:inline;">
      <button type="submit">Supprimer</button>
    </form>

    <!-- Réserver -->
    <a href="/catways/<%= catway._id %>/reserve">Réserver</a>
  </td>
</tr>
<% }) %>
</table>


<hr/>

  <h2>Créer un nouveau catway</h2>
 <form action="/catways" method="POST">
    <input type="text" name="catwayNumber" placeholder="Numéro du catway" required />
      <select name="type" value="type" required/>
      <option value="long">Long</option>
      <option value="short">Short</option>
    </select>
    <input type="text" name="catwayState" placeholder="État du catway" required />
    <button type="submit">Créer Catway</button>
  </form>

<hr/>

  <h2>Modifier un catway par ID</h2>
  <form action="/catways/updateById" method="POST">
    <input type="text" name="id" placeholder="ID du catway à modifier" required />
    <select name="type">
      <option value="">--Type--</option>
      <option value="long">Long</option>
      <option value="short">Short</option>
    </select>
    <input type="text" name="catwayState" placeholder="État" />
    <button type="submit">Modifier Catway</button>
  </form>

<hr/>

  <h2>Supprimer un catway par ID</h2>
  <form action="/catways/deleteById" method="POST">
    <input type="text" name="id" placeholder="ID du catway à supprimer" required />
    <button type="submit">Supprimer Catway</button>
  </form>

<hr>

  <h2>Réservations</h2>

  <!-- Créer réservation -->
  <form action="/api/catways/:id/reservations" method="POST">
    <input type="text" name="catwayNumber" placeholder="Numéro du catway" required />
    <input type="text" name="clientName" placeholder="Nom du client" required />
    <input type="text" name="boatName" placeholder="Nom du bateau" required />
    <input type="date" name="checkIn" placeholder="Date de début" required />
    <input type="date" name="checkOut" placeholder="Date de fin" required />
    <button type="submit">Créer réservation</button>
  </form>

  <!-- Supprimer réservation -->
  <form action="/api/catways/:id/reservations" method="POST">
    <input type="hidden" name="_method" value="DELETE" />
    <input type="text" name="catwayNumber" placeholder="Numéro du catway" required />
    <input type="text" name="reservationId" placeholder="ID réservation" required />
    <button type="submit">Supprimer réservation</button>
  </form>

  <hr>
  <h2>Listes</h2>
  <a href="/catways">Liste des Catways</a> |
  <a href="/reservations">Liste des Réservations</a>
</body>
</html>
