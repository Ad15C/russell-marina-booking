<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Tableau de bord - Port de Plaisance</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 20px; }
    table { border-collapse: collapse; margin-bottom: 15px; width: 100%; }
    th, td { padding: 5px 10px; border: 1px solid #000; text-align: left; }
    form { margin: 5px 0; }
    input, select, button { margin: 2px; padding: 4px; }
    .message { color: green; }
    .error { color: red; }
    h2 { margin-top: 30px; }
  </style>
</head>
<body>
  <h1>Bienvenue <%= user.name %> sur le Port de Plaisance de Russell</h1>
  
<form action="/api/auth/logout" method="POST">
  <button type="submit">Se déconnecter</button>
</form>

 <% if (message) { %>
    <p class="message"><%= message %></p>
  <% } %>
  <% if (error) { %>
    <p class="error"><%= error %></p>
  <% } %>
  
<hr>

  <h2>Gestion des utilisateurs</h2>

  <h3>Créer un nouvel utilisateur</h3>
  <form action="/api/users" method="POST">
    <input type="text" name="name" placeholder="Nom" required />
    <input type="email" name="email" placeholder="Email" required />
    <input type="password" name="password" placeholder="Mot de passe" required />
    <button type="submit">Créer Utilisateur</button>
  </form>
  
  <h3>Modifier un utilisateur</h3>
  <form action="/api/users" method="POST">
      <input type="hidden" name="_method" value="PUT" />
      <input type="text" name="name" placeholder="Nom existant" required />
      <input type="email" name="email" placeholder="Email existant" />
      <input type="text" name="newName" placeholder="Nouveau nom" />
      <input type="email" name="newEmail" placeholder="Nouvel email" />
      <input type="password" name="newPassword" placeholder="Nouveau mot de passe" />
      <button type="submit">Modifier utilisateur</button>
    </form>

  <h3>Supprimer un utilisateur</h3>
    <form action="/api/users/deleteById" method="POST">
      <input type="hidden" name="_method" value="DELETE" />
      <input type="text" name="id" placeholder="ID utilisateur" required />
      <button type="submit">Supprimer utilisateur</button>
    </form>
<hr/>

<h2>Gestion des catways</h2>

  <h3>Liste des Catways</h3>
  <table border="1" cellpadding="5">
    <tr>
      <th>ID</th>
      <th>Numéro</th>
      <th>Type</th>
      <th>État</th>
      <th>Actions</th>
    </tr>
    <% catways.forEach(catway => { %>
      <tr>
        <td><%= catway._id %></td>
        <td><%= catway.catwayNumber %></td>
        <td><%= catway.type %></td>
        <td><%= catway.catwayState %></td>
        <td>
          <!-- Voir détail -->
          <a href="/catways/<%= catway._id %>">Voir</a>

          <!-- Modifier -->
          <form action="/catways/<%= catway._id %>" method="POST">
          <input type="hidden" name="_method" value="PUT">
            <select name="type">
              <option value="">--Type--</option>
              <option value="long" <%= catway.type === 'long' ? 'selected' : '' %>>Long</option>
              <option value="short" <%= catway.type === 'short' ? 'selected' : '' %>>Short</option>
            </select>
            <select name="catwayState" required>
              <option value="libre" <%= catway.catwayState === 'libre' ? 'selected' : '' %>>Libre</option>
              <option value="occupé" <%= catway.catwayState === 'occupé' ? 'selected' : '' %>>Occupé</option>
              <option value="en maintenance" <%= catway.catwayState === 'en maintenance' ? 'selected' : '' %>>En maintenance</option>
            </select>
            <button type="submit">Modifier</button>
          </form>

          <!-- Supprimer depuis le tableau -->
          <form action="/catways/<%= catway._id %>" method="POST" style="display:inline;">
            <input type="hidden" name="_method" value="DELETE">
            <button type="submit">Supprimer</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </table>

  <h3>Créer un nouveau catway</h3>
    <form action="/catways" method="POST">
      <input type="text" name="catwayNumber" placeholder="Numéro" required />
      <select name="type" required>
        <option value="long">Long</option>
        <option value="short">Short</option>
      </select>
      <select name="catwayState" required>
        <option value="libre">Libre</option>
        <option value="occupé">Occupé</option>
        <option value="en maintenance">En maintenance</option>
      </select>
      <button type="submit">Créer un catway</button>
    </form>

  <h3>Modifier un catway par ID</h3>
    <form action="" method="POST" id="updateCatwayForm">
      <input type="text" name="id" id="idInput" placeholder="ID du catway à modifier" required />
      <select name="type">
        <option value="">--Type--</option>
        <option value="long">Long</option>
        <option value="short">Short</option>
      </select>
      <select name="catwayState">
        <option value="libre">Libre</option>
        <option value="occupé">Occupé</option>
        <option value="en maintenance">En maintenance</option>
      </select>
      <button type="submit">Modifier le catway</button>
    </form>

    <script>
      const updateForm = document.getElementById('updateCatwayForm');
      updateForm.addEventListener('submit', function(e){
        const id = document.getElementById('idInput').value;
        updateForm.action = '/catways/' + id; /* vers route Dashboard UI */
        /* ajout method override pour PUT */
        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'PUT';
        updateForm.appendChild(methodInput);
      });
    </script>


  <h3>Supprimer un catway par ID</h3>
    <form action="" method="POST" id="deleteCatwayForm">
      <input type="text" name="id" id="idInputDelete" placeholder="ID du catway à supprimer" required />
      <button type="submit">Supprimer le catway</button>
    </form>

    <script>
      const deleteForm = document.getElementById('deleteCatwayForm');
      deleteForm.addEventListener('submit', function(e){
        const id = document.getElementById('idInputDelete').value;
        deleteForm.action = '/catways/' + id; /* vers route Dashboard UI */
        /* ajout method override pour DELETE */
        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'DELETE';
        deleteForm.appendChild(methodInput);
      });
    </script>

<hr>

  <h2>Gestion des réservations</h2>

    <h3>Créer une réservation</h3>
      <form method="POST" action="/reservations-dashboard">
        <label for="catwayId">Catway :</label>
        <select name="catwayId" id="catwayId" required>
          <option value="">--Choisir un catway--</option>
          <% catways.forEach(catway => { %>
            <option 
              value="<%= catway._id %>" 
              <% if(catway.catwayState !== 'libre'){ %> disabled <% } %>
            >
              Catway <%= catway.catwayNumber %> 
              (<%= catway.catwayState === 'libre' ? 'Disponible' : catway.catwayState === 'occupé' ? 'Occupé' : 'Maintenance' %>)
            </option>
          <% }) %>
        </select>


        <label for="clientName">Nom du client :</label>
        <input type="text" name="clientName" id="clientName" required>

        <label for="boatName">Nom du bateau :</label>
        <input type="text" name="boatName" id="boatName" required>

        <label for="checkIn">Check-in :</label>
        <input type="date" name="checkIn" id="checkIn" required>

        <label for="checkOut">Check-out :</label>
        <input type="date" name="checkOut" id="checkOut" required>

        <button type="submit">Créer réservation</button>
      </form>

    <h3>Supprimer une réservation</h3>
      <form method="POST" id="deleteReservationForm">
        <select name="reservationId" required>
          <option value="">--Choisir une réservation--</option>
          <% reservations.forEach(r => { %>
            <option value="<%= r._id %>"><%= r.clientName %> | Catway <%= r.catwayNumber %></option>
          <% }) %>
        </select>
        <button type="submit">Supprimer réservation</button>
      </form>

      <script>
        const form = document.getElementById('deleteReservationForm');
        form.addEventListener('submit', function (e) {
          e.preventDefault(); // empêche le submit normal
          const reservationId = form.reservationId.value;
          if (!reservationId) return alert("Choisir une réservation");

          // Redirection POST vers la route serveur
          fetch(`/reservations-dashboard/${reservationId}/delete`, {
            method: 'POST'
          })
          .then(() => window.location.href = '/dashboard?message=Réservation supprimée !')
          .catch(err => alert('Erreur suppression: ' + err));
        });
      </script>

    <h3>Liste des Réservations</h3>
    <p id="formError" style="color:red;"></p>
      <table border="1" cellpadding="5">
        <tr>
          <th>ID Réservation</th>
          <th>Client</th>
          <th>Catway</th>
          <th>Action</th>
        </tr>

        <% reservations.forEach(r => { %>
          <tr>
            <td style="font-family: monospace;"><%= r._id %></td>
            <td><%= r.clientName %></td>
            <td><%= r.catwayNumber || r.catwayId?.catwayNumber %></td>
            <td>
              <a href="/reservations/<%= r._id %>">Voir détail</a>
            </td>
          </tr>
        <% }) %>
      </table>


      <h3>Voir les détails d'une réservation</h3>
      <form id="viewReservationForm">
        <input
          type="text"
          name="reservationId"
          placeholder="ID de la réservation"
          required
        />
        <button type="submit">Voir détail réservation</button>
      </form>

      <script>
        const viewForm = document.getElementById('viewReservationForm');

        viewForm.addEventListener('submit', function (e) {
          e.preventDefault();
          const reservationId = viewForm.reservationId.value.trim();
          if (!reservationId) return;
          window.location.href = `/reservations/${reservationId}`;
        });
      </script>

  <hr>

  <h2>Listes</h2>
    <a href="/catways">Liste des Catways</a> |
    <a href="/reservations">Liste des Réservations</a>
    <a href="/documentation">Documentation API</a>

</body>
</html>
