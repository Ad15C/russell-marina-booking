<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Liste des Réservations</title>
  <style>
    body { font-family: Arial, sans-serif; }
    table { border-collapse: collapse; margin-bottom: 15px; }
    th, td { padding: 5px 10px; border: 1px solid #000; }
    .message { color: green; }
    .error { color: red; }
  </style>
</head>
<body>

  <h1>Bienvenue <%= user.name %> sur le Port de Plaisance</h1>

  <% if (message) { %>
    <p class="message"><%= message %></p>
  <% } %>

  <% if (error) { %>
    <p class="error"><%= error %></p>
  <% } %>

  <h2>Liste des Réservations</h2>

  <table>
    <tr>
      <th>ID Réservation</th>
      <th>Client</th>
      <th>Bateau</th>
      <th>Catway</th>
      <th>Check-in</th>
      <th>Check-out</th>
      <th>Actions</th>
    </tr>

    <% reservations.forEach(reservation => { %>
      <tr>
        <td style="font-family: monospace;"><%= reservation._id %></td>
        <td><%= reservation.clientName %></td>
        <td><%= reservation.boatName %></td>
        <td><%= reservation.catwayNumber || reservation.catwayId?.catwayNumber %></td>
        <td><%= new Date(reservation.checkIn).toLocaleDateString() %></td>
        <td><%= new Date(reservation.checkOut).toLocaleDateString() %></td>
        <td>
          <!-- Voir détail (UI) -->
          <a href="/reservations/<%= reservation._id %>">Voir</a>

           <!-- Supprimer via dashboard -->
        <form method="POST" action="/reservations/<%= reservation._id %>/delete" style="display:inline;">
          <button type="submit">Supprimer</button>
        </form>
        </td>
      </tr>
    <% }) %>
  </table>

  <hr>

  <!-- FORMULAIRE DE CRÉATION DE RÉSERVATION -->
  <h2>Créer une réservation</h2>
        <form method="POST" action="/reservations">
            <input type="hidden" name="redirectTo" value="/reservations">
            <label for="catwayId">Catway :</label>
            <select name="catwayId" id="catwayId" required>
            <option value="">--Choisir un catway--</option>
            <% catways.forEach(catway => { %>
                <option 
                value="<%= catway._id %>" 
                <% if(catway.catwayState !== 'libre'){ %> disabled <% } %>
                >
                Catway <%= catway.catwayNumber %> 
                (<%= catway.catwayState === 'libre' ? 'Disponible' : catway.catwayState === 'occupé' ? 'Occupé' : 'Maintenance' %>)
                </option>
            <% }) %>
            </select>


            <label for="clientName">Nom du client :</label>
            <input type="text" name="clientName" id="clientName" required>

            <label for="boatName">Nom du bateau :</label>
            <input type="text" name="boatName" id="boatName" required>

            <label for="checkIn">Check-in :</label>
            <input type="date" name="checkIn" id="checkIn" required>

            <label for="checkOut">Check-out :</label>
            <input type="date" name="checkOut" id="checkOut" required>

            <button type="submit">Créer réservation</button>
        </form>


  <p>
    <a href="/dashboard">← Retour au Dashboard</a>
  </p>

</body>
</html>
